---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/layout/Navbar.astro';
import Footer from '../components/layout/Footer.astro';
import TradeFeed from '../components/feed/TradeFeed.tsx';
---

<Layout title="Trade Feed — Stockade" description="See what other traders are doing in real time.">
  <Navbar />
  <main class="max-w-[860px] mx-auto px-4 py-8">
    <div class="mb-8">
      <div class="text-[11px] font-mono uppercase tracking-widest text-[#f59e0b] mb-2">Community</div>
      <h1 class="text-3xl font-bold tracking-tight text-[#f5f5f5]">Live Trade Feed</h1>
      <p class="mt-2 text-[#666666] text-[14px]">See what traders are doing right now.</p>
    </div>
    <TradeFeed client:load />
  </main>
  <Footer />
</Layout>
