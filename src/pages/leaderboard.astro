---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/layout/Navbar.astro';
import Footer from '../components/layout/Footer.astro';
import Leaderboard from '../components/leaderboard/Leaderboard.tsx';
---

<Layout title="Leaderboard — Stockade" description="Top traders on the Stockade simulator.">
  <Navbar />
  <main class="max-w-[1100px] mx-auto px-4 py-8">
    <div class="mb-8">
      <div class="text-[11px] font-mono uppercase tracking-widest text-[#f59e0b] mb-2">Rankings</div>
      <h1 class="text-3xl font-bold tracking-tight text-[#f5f5f5]">Global Leaderboard</h1>
      <p class="mt-2 text-[#666666] text-[14px]">Top performers ranked by simulated profit factor this week.</p>
    </div>
    <Leaderboard client:load />
  </main>
  <Footer />
</Layout>
