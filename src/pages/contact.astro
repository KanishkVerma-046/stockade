---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/layout/Navbar.astro';
import Footer from '../components/layout/Footer.astro';
---

<Layout
  title="Contact | Stockade"
  description="Get in touch with the Stockade team. Have a question, found a bug, or want to suggest a feature? We're happy to hear from you."
  canonical="https://stockademarketsim.com/contact"
>
  <Navbar />

  <main class="max-w-[680px] mx-auto px-6 py-16">

    <div class="mb-10">
      <div class="text-[11px] font-mono uppercase tracking-widest text-[#f59e0b] mb-3">Contact</div>
      <h1 class="text-4xl font-bold tracking-tight text-[var(--c-text)] mb-3">Get in touch</h1>
      <p class="text-[16px] text-[var(--c-text-muted)] leading-relaxed">
        Have a question, found a bug, or want to suggest a feature? Drop us a message and we'll
        get back to you as soon as we can.
      </p>
    </div>

    <!-- Contact form -->
    <form
      id="contact-form"
      class="space-y-5 mb-12"
      novalidate
    >
      <div class="grid sm:grid-cols-2 gap-5">
        <div>
          <label for="name" class="block text-[12px] font-mono uppercase tracking-widest text-[var(--c-text-subtle)] mb-1.5">
            Name
          </label>
          <input
            id="name"
            name="name"
            type="text"
            placeholder="Your name"
            required
            class="w-full bg-[var(--c-bg-soft)] border border-[var(--c-border)] rounded-lg px-4 py-2.5 text-[14px] text-[var(--c-text)] placeholder-[var(--c-text-subtle)] focus:outline-none focus:border-[#f59e0b] transition-colors"
          />
        </div>
        <div>
          <label for="email" class="block text-[12px] font-mono uppercase tracking-widest text-[var(--c-text-subtle)] mb-1.5">
            Email
          </label>
          <input
            id="email"
            name="email"
            type="email"
            placeholder="you@example.com"
            required
            class="w-full bg-[var(--c-bg-soft)] border border-[var(--c-border)] rounded-lg px-4 py-2.5 text-[14px] text-[var(--c-text)] placeholder-[var(--c-text-subtle)] focus:outline-none focus:border-[#f59e0b] transition-colors"
          />
        </div>
      </div>

      <div>
        <label for="subject" class="block text-[12px] font-mono uppercase tracking-widest text-[var(--c-text-subtle)] mb-1.5">
          Subject
        </label>
        <select
          id="subject"
          name="subject"
          class="w-full bg-[var(--c-bg-soft)] border border-[var(--c-border)] rounded-lg px-4 py-2.5 text-[14px] text-[var(--c-text)] focus:outline-none focus:border-[#f59e0b] transition-colors appearance-none"
        >
          <option value="general">General question</option>
          <option value="bug">Bug report</option>
          <option value="feature">Feature request</option>
          <option value="feedback">Feedback</option>
          <option value="other">Other</option>
        </select>
      </div>

      <div>
        <label for="message" class="block text-[12px] font-mono uppercase tracking-widest text-[var(--c-text-subtle)] mb-1.5">
          Message
        </label>
        <textarea
          id="message"
          name="message"
          rows="6"
          placeholder="Tell us what's on your mind..."
          required
          class="w-full bg-[var(--c-bg-soft)] border border-[var(--c-border)] rounded-lg px-4 py-2.5 text-[14px] text-[var(--c-text)] placeholder-[var(--c-text-subtle)] focus:outline-none focus:border-[#f59e0b] transition-colors resize-none"
        ></textarea>
      </div>

      <div id="form-error" class="hidden text-[13px] text-[#ef4444] bg-[rgba(239,68,68,0.08)] border border-[rgba(239,68,68,0.2)] rounded-lg px-4 py-2.5"></div>
      <div id="form-success" class="hidden text-[13px] text-[#22c55e] bg-[rgba(34,197,94,0.08)] border border-[rgba(34,197,94,0.2)] rounded-lg px-4 py-2.5">
        Message sent — thanks! We'll get back to you shortly.
      </div>

      <button
        type="submit"
        id="submit-btn"
        class="px-6 py-2.5 rounded-full bg-[#f59e0b] text-[#0a0a0a] font-semibold text-[14px] hover:bg-[#fbbf24] transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
      >
        Send message →
      </button>
    </form>

    <!-- Divider -->
    <div class="border-t border-[var(--c-border)] pt-10">
      <div class="text-[11px] font-mono uppercase tracking-widest text-[var(--c-text-subtle)] mb-4">Or reach us directly</div>
      <a
        href="mailto:hello@stockademarketsim.com"
        class="inline-flex items-center gap-2 text-[#f59e0b] hover:text-[#fbbf24] transition-colors text-[15px]"
      >
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
          <rect x="1" y="3" width="14" height="10" rx="1.5"/>
          <path d="M1 4l7 5 7-5" stroke-linejoin="round"/>
        </svg>
        hello@stockademarketsim.com
      </a>
    </div>

    <!-- FAQ nudge -->
    <div class="mt-8 bg-[var(--c-bg-soft)] border border-[var(--c-border)] rounded-xl p-5">
      <p class="text-[13px] text-[var(--c-text-subtle)] leading-relaxed">
        Looking for quick answers? Check the
        <a href="/#faq" class="text-[#f59e0b] hover:text-[#fbbf24] underline underline-offset-2">FAQ section</a>
        on the home page — it covers the most common questions about how the simulator works.
      </p>
    </div>

  </main>

  <Footer />
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const errorBox = document.getElementById('form-error')!;
  const successBox = document.getElementById('form-success')!;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorBox.classList.add('hidden');
    successBox.classList.add('hidden');

    const name = (document.getElementById('name') as HTMLInputElement).value.trim();
    const email = (document.getElementById('email') as HTMLInputElement).value.trim();
    const message = (document.getElementById('message') as HTMLTextAreaElement).value.trim();

    if (!name || !email || !message) {
      errorBox.textContent = 'Please fill in all required fields.';
      errorBox.classList.remove('hidden');
      return;
    }

    const emailOk = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
    if (!emailOk) {
      errorBox.textContent = 'Please enter a valid email address.';
      errorBox.classList.remove('hidden');
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending…';

    // Compose a mailto: link as the fallback (no backend)
    const subject = (document.getElementById('subject') as HTMLSelectElement).value;
    const body = `Name: ${name}\nEmail: ${email}\nSubject: ${subject}\n\n${message}`;
    const mailto = `mailto:hello@stockademarketsim.com?subject=${encodeURIComponent(`[Stockade] ${subject}`)}&body=${encodeURIComponent(body)}`;
    window.location.href = mailto;

    setTimeout(() => {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Send message →';
      successBox.classList.remove('hidden');
      form.reset();
    }, 800);
  });
</script>
