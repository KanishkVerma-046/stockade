---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/layout/Navbar.astro';
import Footer from '../components/layout/Footer.astro';
import TickerTape from '../components/landing/TickerTape.tsx';
import LiveStats from '../components/landing/LiveStats.tsx';
---

<Layout
  title="Free Stock Market Simulator — Practice Trading Online | Stockade"
  description="A free stock market simulator. Practice day trading, paper trading & crypto trading with $100K virtual money. No signup required. Stocks, forex, futures & crypto simulator online."
  keywords="stock market simulator, stock market simulator game, stock market simulator for students, stock market simulator app, free stock market simulator, fake stock market simulator, stock market simulator free, virtual stock market simulator, stock market simulator & game, online stock market simulator, stock market simulator game online, stock market simulator for students free, stock market simulator online, trading simulator, day trading simulator, paper trading simulator, stock trading simulator, day trading simulator free, trading simulator free, free day trading simulator, futures trading simulator, crypto trading simulator, fake trading simulator, forex trading simulator, fake day trading simulator"
  canonical="https://stockademarketsim.com/"
>
  <Fragment slot="head">
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "WebSite",
            "@id": "https://stockademarketsim.com/#website",
            "url": "https://stockademarketsim.com/",
            "name": "Stockade",
            "description": "Free stock market simulator. Practice trading stocks, crypto, forex, and futures with $100K virtual money.",
            "potentialAction": {
              "@type": "SearchAction",
              "target": {
                "@type": "EntryPoint",
                "urlTemplate": "https://stockademarketsim.com/markets"
              },
              "query-input": "required name=search_term_string"
            }
          },
          {
            "@type": "SoftwareApplication",
            "@id": "https://stockademarketsim.com/#app",
            "name": "Stockade Stock Market Simulator",
            "url": "https://stockademarketsim.com/",
            "applicationCategory": "FinanceApplication",
            "operatingSystem": "Web Browser",
            "offers": {
              "@type": "Offer",
              "price": "0",
              "priceCurrency": "USD"
            },
            "description": "Free online stock market simulator for paper trading stocks, crypto, forex, and futures. No signup required.",
            "screenshot": "https://stockademarketsim.com/og-image.png",
            "featureList": [
              "Real candlestick charts with volume",
              "EMA, VWAP, RSI, MACD indicators",
              "Market, limit, stop-loss, and bracket orders",
              "Paper trading with $100,000 virtual balance",
              "Analytics dashboard with equity curve",
              "Stocks, crypto, forex, and futures"
            ],
            "aggregateRating": {
              "@type": "AggregateRating",
              "ratingValue": "4.9",
              "ratingCount": "1200"
            }
          },
          {
            "@type": "Organization",
            "@id": "https://stockademarketsim.com/#organization",
            "name": "Stockade",
            "url": "https://stockademarketsim.com/",
            "logo": "https://stockademarketsim.com/favicon-96x96.png",
            "sameAs": []
          }
        ]
      }
    </script>
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "Is Stockade a completely free stock market simulator?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Yes. Stockade is 100% free forever. Every feature, every asset class, and every tool is included at no cost. No signup, no credit card, no subscription required."
            }
          },
          {
            "@type": "Question",
            "name": "Can students use Stockade as a stock market simulator?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Absolutely. Stockade is one of the best free stock market simulators for students. It requires no installation or account creation, making it ideal for classroom use, university finance courses, and self-directed learning."
            }
          },
          {
            "@type": "Question",
            "name": "Does Stockade support crypto, forex, and futures trading simulation?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Yes. Stockade is a multi-asset trading simulator covering stocks, cryptocurrency, forex pairs, and futures contracts (NQ, ES, CL, GC) — all in one free platform."
            }
          },
          {
            "@type": "Question",
            "name": "Is Stockade a paper trading or day trading simulator?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Stockade functions as both a paper trading simulator and a day trading simulator. You can replay historical sessions candle-by-candle or trade live with 800ms price ticks, both with $100,000 in virtual money."
            }
          },
          {
            "@type": "Question",
            "name": "What is a stock market simulator?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "A stock market simulator is a virtual trading platform that replicates real market conditions using fake money, so you can practice buying and selling stocks, crypto, forex, and futures without any financial risk. Stockade gives you $100,000 in virtual capital and professional-grade tools — candlestick charts, technical indicators, and multiple order types — all in your browser with no signup required."
            }
          },
          {
            "@type": "Question",
            "name": "What can I do with a stock market simulator?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "With Stockade you can practice buying and selling stocks, crypto, forex pairs, and futures contracts; test trading strategies against historical data; track performance through an analytics dashboard with equity curves, win rate, and drawdown metrics; and build the pattern recognition and discipline needed for real markets — all completely risk-free."
            }
          },
          {
            "@type": "Question",
            "name": "Is the stock market simulator real or fake?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "The money is entirely virtual — you start with $100,000 in paper capital so there is zero financial risk. The prices and charts use realistic simulated market data designed to mirror real brokerage behavior. The trading mechanics, chart patterns, indicators, and order types are all modeled on real-world platforms, so the skill-building is genuine even though the money is not."
            }
          },
          {
            "@type": "Question",
            "name": "How does a stock market simulator work?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Stockade generates realistic price data for 29 assets across stocks, crypto, forex, and futures. You place orders through a full order panel — market, limit, stop-loss, take-profit, and OCO bracket orders — and the simulator fills them instantly. Your virtual P&L, equity curve, win rate, and performance metrics are tracked automatically in your browser with no account or installation required."
            }
          },
          {
            "@type": "Question",
            "name": "What are the risks of using a stock market simulator?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "The main risk is developing habits that don't fully account for real-market factors such as slippage, liquidity constraints, brokerage fees, and the psychological pressure of trading real money. Stockade is designed for skill-building and education, not as a guarantee of live-trading results. When you transition to real markets, always start with small position sizes to account for the emotional and execution differences."
            }
          },
          {
            "@type": "Question",
            "name": "What are the limitations of the simulator?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Stockade uses simulated price data rather than a live market feed, so exact real-world spreads, slippage, and after-hours gaps are approximated rather than precisely reproduced. It also cannot fully replicate the psychological pressure that comes with risking real capital — an important variable in live-trading performance. Think of it as a training ground that covers all the technical skills while acknowledging that emotional discipline develops further in live markets."
            }
          },
          {
            "@type": "Question",
            "name": "What is the main advantage of a simulator?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "The main advantage is zero financial risk while developing real trading skills. You can test strategies, make expensive mistakes, and build discipline without losing any money. Stockade provides $100,000 in virtual capital alongside professional tools — candlestick charts, EMA/VWAP/RSI/MACD indicators, a full order panel, and a detailed analytics dashboard — the same environment you'd find in a real brokerage, but completely free and consequence-free."
            }
          }
        ]
      }
    </script>
  </Fragment>

  <Navbar />

  <!-- ── Hero ── -->
  <section class="relative overflow-hidden mesh-gradient">
    <!-- Grid overlay -->
    <div
      class="absolute inset-0 opacity-[0.03]"
      style="background-image: linear-gradient(var(--c-text) 1px, transparent 1px), linear-gradient(90deg, var(--c-text) 1px, transparent 1px); background-size: 40px 40px;"
    ></div>

    <div class="relative max-w-[1100px] mx-auto px-6 pt-24 pb-28 text-center">
      <!-- Eyebrow -->
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-[var(--c-amber-bg)] border border-[var(--c-amber-dim)] text-[#f59e0b] text-[12px] font-mono mb-8">
        <span class="w-1.5 h-1.5 rounded-full bg-[#22c55e] animate-pulse"></span>
        Free · No Signup · $100K Virtual Balance
      </div>

      <!-- Headline -->
      <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold tracking-tight leading-[1.05] mb-6">
        Practice the market.
        <br />
        <span class="gradient-text">Master the game.</span>
      </h1>

      <!-- Subhead -->
      <p class="text-lg sm:text-xl text-[var(--c-text-muted)] max-w-[600px] mx-auto mb-10 leading-relaxed">
        The free stock &amp; crypto trading simulator with realistic simulated market data.
        No signup. No risk. Just trading.
      </p>

      <!-- CTAs -->
      <div class="flex flex-wrap justify-center gap-3 mb-16">
        <a
          href="/simulator"
          class="px-6 py-3 rounded-full bg-[#f59e0b] text-[#0a0a0a] font-semibold text-[15px] hover:bg-[#fbbf24] transition-colors"
        >
          Start Trading Free →
        </a>
        <a
          href="/markets"
          class="px-6 py-3 rounded-full bg-[var(--c-bg-muted)] text-[var(--c-text)] font-semibold text-[15px] border border-[var(--c-border)] hover:bg-[var(--c-surface-2)] transition-colors"
        >
          View Markets
        </a>
      </div>

      <!-- Live stats -->
      <LiveStats client:load />
    </div>
  </section>

  <!-- ── App preview ── -->
