---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/layout/Navbar.astro';
import Footer from '../components/layout/Footer.astro';
import AnalyticsDashboard from '../components/analytics/AnalyticsDashboard.tsx';
---

<Layout
  title="Trading Analytics Dashboard | Stockade"
  description="Analyze your paper trading performance with equity curves, win rates, drawdown metrics, profit factor, and trade journals on Stockade's free stock market simulator."
  keywords="paper trading simulator, trading simulator, stock market simulator, day trading simulator, free trading simulator, stock trading simulator"
  canonical="https://stockademarketsim.com/analytics"
>
  <Navbar />
  <main class="max-w-[1400px] mx-auto px-4 py-8">
    <div class="mb-8">
      <div class="text-[11px] font-mono uppercase tracking-widest text-[#f59e0b] mb-2">Analytics</div>
      <h1 class="text-3xl font-bold tracking-tight text-[var(--c-text)]">Performance Dashboard</h1>
      <p class="mt-2 text-[var(--c-text-subtle)] text-[14px]">Your simulated trading statistics — equity curve, win rate, drawdown, and trade journal.</p>
    </div>
    <AnalyticsDashboard client:load />
  </main>
  <Footer />
</Layout>
