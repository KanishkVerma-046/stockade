---
const year = new Date().getFullYear();
---

<footer class="border-t border-[#2a2a2a] bg-[#0a0a0a] mt-auto">
  <div class="max-w-[1400px] mx-auto px-6 py-12">
    <div class="grid grid-cols-2 md:grid-cols-5 gap-8 mb-12">
      <!-- Brand -->
      <div class="col-span-2">
        <a href="/" class="flex items-center gap-2 mb-4">
          <div class="w-7 h-7 rounded-md bg-[#f59e0b] flex items-center justify-center">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path d="M2 12L6 7L10 9L14 3" stroke="#0a0a0a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <span class="text-[15px] font-semibold text-[#f5f5f5]">Stockade</span>
        </a>
        <p class="text-[13px] text-[#666666] leading-relaxed max-w-[220px]">
          Practice the market. Master the game. Completely free — no signup required.
        </p>
        <p class="mt-4 text-[11px] font-mono text-[#f59e0b]">stockade.io</p>
      </div>

      <!-- Product -->
      <div>
        <p class="text-[11px] font-mono uppercase tracking-widest text-[#666666] mb-3">Product</p>
        <ul class="space-y-2">
          {[
            { href: '/simulator', label: 'Simulator' },
            { href: '/markets',   label: 'Markets' },
            { href: '/analytics', label: 'Analytics' },
          ].map(l => (
            <li>
              <a href={l.href} class="text-[13px] text-[#a1a1a1] hover:text-[#f5f5f5] transition-colors">{l.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Community -->
      <div>
        <p class="text-[11px] font-mono uppercase tracking-widest text-[#666666] mb-3">Community</p>
        <ul class="space-y-2">
          {[
            { href: '/leaderboard', label: 'Leaderboard' },
            { href: '/feed',        label: 'Trade Feed' },
          ].map(l => (
            <li>
              <a href={l.href} class="text-[13px] text-[#a1a1a1] hover:text-[#f5f5f5] transition-colors">{l.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <p class="text-[11px] font-mono uppercase tracking-widest text-[#666666] mb-3">Legal</p>
        <ul class="space-y-2">
          {[
            { href: '#', label: 'Privacy' },
            { href: '#', label: 'Terms' },
            { href: '#', label: 'Disclaimer' },
          ].map(l => (
            <li>
              <a href={l.href} class="text-[13px] text-[#a1a1a1] hover:text-[#f5f5f5] transition-colors">{l.label}</a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="pt-6 border-t border-[#1a1a1a] flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3">
      <p class="text-[12px] text-[#666666]">
        © {year} Stockade. All rights reserved.
      </p>
      <p class="text-[11px] text-[#444444] leading-relaxed max-w-[480px]">
        Stockade is a simulation platform only. All trading is done with virtual money. This is not financial advice. Past simulated performance does not indicate future real results.
      </p>
    </div>
  </div>
</footer>
