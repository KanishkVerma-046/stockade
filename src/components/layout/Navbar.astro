---
interface Props {
  compact?: boolean;
}
const { compact = false } = Astro.props;
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/simulator', label: 'Simulator' },
  { href: '/markets',   label: 'Markets' },
  { href: '/analytics', label: 'Analytics' },
  { href: '/leaderboard', label: 'Leaderboard' },
  { href: '/feed',      label: 'Feed' },
];

function isActive(href: string) {
  return currentPath === href || (href !== '/' && currentPath.startsWith(href));
}
---

<nav
  class:list={[
    'sticky top-0 z-50 border-b border-[var(--c-border)] navbar-bg backdrop-blur-md',
    compact ? 'h-12' : 'h-14',
  ]}
>
  <div class="max-w-[1400px] mx-auto px-4 h-full flex items-center gap-6">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 shrink-0 group">
      <div class="w-7 h-7 rounded-md bg-[#f59e0b] flex items-center justify-center">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M2 12L6 7L10 9L14 3" stroke="#0a0a0a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <span class="text-[15px] font-semibold tracking-tight text-[var(--c-text)] group-hover:text-[#f59e0b] transition-colors">
        Stockade
      </span>
    </a>

    <!-- Nav links — desktop -->
    <div class="hidden md:flex items-center gap-1 flex-1">
      {navLinks.map(link => (
        <a
          href={link.href}
          class:list={[
            'px-3 py-1.5 rounded-md text-[13px] transition-colors',
            isActive(link.href)
              ? 'text-[var(--c-text)] bg-[var(--c-surface)]'
              : 'text-[var(--c-text-muted)] hover:text-[var(--c-text)] hover:bg-[var(--c-bg-muted)]',
          ]}
        >
          {link.label}
        </a>
      ))}
    </div>

    <!-- Right cluster -->
    <div class="ml-auto flex items-center gap-2">
      <!-- Status badge -->
      <div class="hidden sm:flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-[var(--c-green-bg)] border border-[var(--c-green-dim)] text-[#22c55e] text-[11px] font-mono">
        <span class="w-1.5 h-1.5 rounded-full bg-[#22c55e] animate-pulse"></span>
        Live
      </div>

      <!-- Fullscreen toggle -->
      <button
        id="fullscreen-toggle"
        aria-label="Toggle fullscreen"
        title="Toggle fullscreen"
        class="p-1.5 rounded-md text-[var(--c-text-muted)] hover:text-[var(--c-text)] hover:bg-[var(--c-bg-muted)] transition-colors"
      >
        <svg id="fs-icon-expand" width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M1 5V1h4M15 5V1h-4M1 11v4h4M15 11v4h-4"/>
        </svg>
        <svg id="fs-icon-compress" width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" class="hidden">
          <path d="M5 1v4H1M11 1v4h4M5 15v-4H1M11 15v-4h4"/>
        </svg>
      </button>

      <!-- Theme toggle -->
      <button
        id="theme-toggle"
        aria-label="Toggle light/dark mode"
        class="p-1.5 rounded-md text-[var(--c-text-muted)] hover:text-[var(--c-text)] hover:bg-[var(--c-bg-muted)] transition-colors"
        title="Toggle light/dark mode"
      >
        <!-- Sun icon (shown in dark mode) -->
        <svg id="theme-icon-sun" width="16" height="16" viewBox="0 0 16 16" fill="none" class="hidden">
          <circle cx="8" cy="8" r="3" stroke="currentColor" stroke-width="1.5"/>
          <path d="M8 1v1.5M8 13.5V15M1 8h1.5M13.5 8H15M3.05 3.05l1.06 1.06M11.89 11.89l1.06 1.06M3.05 12.95l1.06-1.06M11.89 4.11l1.06-1.06" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        <!-- Moon icon (shown in light mode) -->
        <svg id="theme-icon-moon" width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M13.5 10.5A6 6 0 015.5 2.5a6 6 0 000 11A6 6 0 0013.5 10.5z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
        </svg>
      </button>

      <a
        href="/simulator"
        class="px-3 py-1.5 rounded-md bg-[#f59e0b] text-[#0a0a0a] text-[13px] font-semibold hover:bg-[#fbbf24] transition-colors whitespace-nowrap"
      >
        Start Trading
      </a>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-1.5 rounded-md text-[var(--c-text-muted)] hover:text-[var(--c-text)] hover:bg-[var(--c-bg-muted)] transition-colors"
        aria-label="Menu"
      >
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
          <path d="M3 5h12M3 9h12M3 13h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile drawer -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t border-[var(--c-border)] bg-[var(--c-bg)] px-4 py-3 flex flex-col gap-1"
  >
    {navLinks.map(link => (
      <a
        href={link.href}
        class:list={[
          'px-3 py-2 rounded-md text-[14px] transition-colors',
          isActive(link.href)
            ? 'text-[var(--c-text)] bg-[var(--c-surface)]'
            : 'text-[var(--c-text-muted)] hover:text-[var(--c-text)] hover:bg-[var(--c-bg-muted)]',
        ]}
      >
        {link.label}
      </a>
    ))}
  </div>
</nav>

<script>
  // Fullscreen toggle
  const fsBtn      = document.getElementById('fullscreen-toggle');
  const fsExpand   = document.getElementById('fs-icon-expand');
  const fsCompress = document.getElementById('fs-icon-compress');

  function updateFsIcons() {
    const full = !!document.fullscreenElement;
    fsExpand?.classList.toggle('hidden', full);
    fsCompress?.classList.toggle('hidden', !full);
  }

  fsBtn?.addEventListener('click', () => {
    if (!document.fullscreenElement) document.documentElement.requestFullscreen();
    else document.exitFullscreen();
  });

  document.addEventListener('fullscreenchange', updateFsIcons);

  // Mobile menu
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));

  // Theme toggle
  const toggle = document.getElementById('theme-toggle');
  const sunIcon = document.getElementById('theme-icon-sun');
  const moonIcon = document.getElementById('theme-icon-moon');

  function applyThemeIcons() {
    const isLight = document.documentElement.classList.contains('light');
    sunIcon?.classList.toggle('hidden', !isLight);
    moonIcon?.classList.toggle('hidden', isLight);
  }

  applyThemeIcons();

  toggle?.addEventListener('click', () => {
    const isLight = document.documentElement.classList.toggle('light');
    localStorage.setItem('theme', isLight ? 'light' : 'dark');
    applyThemeIcons();
  });
</script>
