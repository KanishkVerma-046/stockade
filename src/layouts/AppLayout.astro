---
import '../styles/global.css';
import Navbar from '../components/layout/Navbar.astro';
import TickerTape from '../components/landing/TickerTape.tsx';

interface Props {
  title?: string;
  description?: string;
  keywords?: string;
  ogImage?: string;
  canonical?: string;
}

const {
  title = 'Stockade — Free Stock Market Simulator',
  description = 'Free stock market trading simulator. Practice day trading, paper trading, and crypto with $100K virtual money. No signup required.',
  keywords = 'stock market simulator, paper trading simulator, day trading simulator, trading simulator, stock trading simulator',
  ogImage = '/og-image.png',
  canonical,
} = Astro.props;

const siteUrl = 'https://stockademarketsim.com';
const canonicalUrl = canonical ?? `${siteUrl}${Astro.url.pathname}`;
const ogImageUrl = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="robots" content="index, follow" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Stockade" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Stockade — Free Stock Market Simulator" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@stockade_io" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Favicons -->
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="Stockade" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <slot name="head" />
    <!-- Apply saved theme before render to avoid flash -->
    <script is:inline>
      try {
        if (localStorage.getItem('theme') === 'light') {
          document.documentElement.classList.add('light');
        }
      } catch {}
    </script>
  </head>
  <body class="bg-[var(--c-bg)] text-[var(--c-text)] h-screen flex flex-col overflow-hidden">
    <Navbar compact />
    <main class="flex-1 overflow-hidden">
      <slot />
    </main>
    <div class="shrink-0 border-t border-[var(--c-border)]">
      <TickerTape client:load />
    </div>
  </body>
</html>
